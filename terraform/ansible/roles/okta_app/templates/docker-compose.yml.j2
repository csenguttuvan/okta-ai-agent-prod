
networks:
  logging:
    driver: bridge

services:
  # Okta MCP Server - Admin (Read/Write)
  okta-mcp-admin:
    image: "blackstaa/okta-mcp-server:{{ mcp_image_tag | default('latest') }}"
    container_name: okta-mcp-admin
    network_mode: "host"
    volumes:
      - ./keys:/app/keys:ro
    env_file:
      - .env
    environment:
      - OKTA_PRIVATE_KEY_PATH=/app/keys/admin_private_key.pem
      - OKTA_CLIENT_ID={{ okta_admin_client_id }}
      - OKTA_SCOPES={{ okta_admin_scopes }}
      - MCP_TRANSPORT=sse
      - MCP_PORT=8080
      - MCP_HOST=0.0.0.0
      - MCP_SERVER_NAME=okta-admin
      - ACCESS_LEVEL=admin
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -f --silent --max-time 2 http://localhost:8080/sse | head -c 1 > /dev/null"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

  # Okta MCP Server - Readonly
  okta-mcp-readonly:
    image: "blackstaa/okta-mcp-server:{{ mcp_image_tag | default('latest') }}"
    container_name: okta-mcp-readonly
    network_mode: "host"
    volumes:
      - ./keys:/app/keys:ro
    env_file:
      - .env
    environment:
      - OKTA_PRIVATE_KEY_PATH=/app/keys/readonly_private_key.pem
      - OKTA_CLIENT_ID={{ okta_readonly_client_id }}
      - OKTA_SCOPES={{ okta_readonly_scopes }}
      - MCP_TRANSPORT=sse
      - MCP_PORT=8081
      - MCP_HOST=0.0.0.0
      - MCP_SERVER_NAME=okta-readonly
      - ACCESS_LEVEL=readonly
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -f --silent --max-time 2 http://localhost:8081/sse | head -c 1 > /dev/null"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

  # LiteLLM Proxy - AI Gateway
  litellm:
    image: ghcr.io/berriai/litellm:{{ litellm_version }}  # ✅ PINNED
    container_name: litellm-proxy
    network_mode: "host"
    volumes:
      - ./litellm-config.yaml:/app/config.yaml:ro
      - {{ storage_directory }}/litellm-data:/app/data
      - ./custom_callbacks.py:/app/custom_callbacks.py:ro
    env_file:
      - .env
    environment:
      - PORT=4002  # ✅ CHANGED: Container listens on 4002 instead of 4001
      - LITELLM_LOG=DEBUG
      - PYTHONPATH=/app
    command: ["--config", "/app/config.yaml", "--port", "4002", "--num_workers", "1"]  # ✅ CHANGED PORT
    restart: unless-stopped
    depends_on:
      - redis


  # Loki - Log aggregation
  loki:
    image: grafana/loki:{{ loki_version }}
    container_name: loki
    user: "10001:10001"
    command: -config.file=/etc/loki/config/loki-config.yaml
    volumes:
      - ./loki-config.yaml:/etc/loki/config/loki-config.yaml:ro
      - {{ storage_directory }}/loki-data:/loki
      - {{ storage_directory }}/loki-wal:/wal
    ports:
      - "3100:3100"
    networks:
      - logging
    restart: unless-stopped

  # Grafana Alloy - Log shipper
  alloy:
    image: grafana/alloy:{{ alloy_version }}
    container_name: alloy
    command:
      - run
      - /etc/alloy/config.alloy
      - --storage.path=/var/lib/alloy/data
    volumes:
      - ./alloy-config.alloy:/etc/alloy/config.alloy:ro
      - {{ storage_directory }}/alloy-data:/var/lib/alloy/data
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - logging
    restart: unless-stopped
    depends_on:
      - loki


  # Grafana - Observability Dashboard
  grafana:
    image: grafana/grafana:{{ grafana_version }}
    container_name: grafana
    user: "472:472"
    # ports:
    #   - "3002:3000"  # ✅ CHANGED: Map host 3002 to container 3001 (avoid conflict with old project)
    environment:
      - GF_SERVER_HTTP_PORT=3002
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=admin
      - GF_SERVER_ROOT_URL=http://localhost:10039
      - GF_SERVER_DOMAIN=localhost
    volumes:
      - {{ storage_directory }}/grafana/data:/var/lib/grafana 
      - {{ storage_directory }}/grafana/provisioning:/etc/grafana/provisioning:ro # host path -> container path
    network_mode: "host"
    restart: unless-stopped

  # Redis - Caching layer for LiteLLM
  redis:
    image: redis:{{ redis_version }}
    container_name: litellm-redis
    volumes:
      - {{ storage_directory }}/redis-data:/data
    network_mode: "host"
    command: redis-server --save "" --appendonly no --stop-writes-on-bgsave-error no
    restart: unless-stopped
