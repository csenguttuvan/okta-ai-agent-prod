*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
*.tfvars
!terraform.tfvars.example


# Secrets and keys
secrets/
*.pem
*.key
*.crt
*.p12
id_rsa*
*.ppk

# Configuration files with sensitive data
config/production.yaml
config/staging.yaml
config/local.yaml
claude_desktop_config.json
!claude_desktop_config.json.example

# Docker
docker-compose.override.yml
.dockerignore

