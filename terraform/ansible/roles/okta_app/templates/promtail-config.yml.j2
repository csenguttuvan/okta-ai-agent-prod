# ansible/roles/okta_app/templates/promtail-config.yml.j2
server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://loki:3100/loki/api/v1/push

scrape_configs:
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: 'container_name'
        action: replace
      - source_labels: ['__meta_docker_container_id']
        target_label: 'container_id'
        action: replace
      - target_label: 'job'
        replacement: 'docker'
      - target_label: 'cluster'
        replacement: 'okta-litellm-prod'  # ✅ Different from old project
      - target_label: 'host'
        replacement: 'ec2-prod-instance'  # ✅ Different from old project
